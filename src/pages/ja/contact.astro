---
import { TooltipProvider } from "@/components/ui/tooltip";
import { SidebarLayout } from "@/components/sidebar-layout";

import "../../styles/global.css";

import { Mail, Linkedin, Github } from "lucide-react";

const contacts = [
  {
    icon: Mail,
    label: "メール",
    value: "tom.bath.connect@gmail.com",
    href: "mailto:tom.bath.connect@gmail.com",
  },
  {
    icon: Linkedin,
    label: "LinkedIn",
    value: "linkedin.com/in/tom-bath",
    href: "https://linkedin.com/in/tom-bath",
  },
  {
    icon: Github,
    label: "GitHub",
    value: "github.com/Tom-Bath",
    href: "https://github.com/Tom-Bath",
  },
];
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>お問い合わせ - Tom Bath</title>
  </head>
  <body class="bg-background text-foreground">
    <SidebarLayout client:load title="お問い合わせ" baseUrl={import.meta.env.BASE_URL} locale="ja">
      <TooltipProvider client:load>
        <div class="flex-1 flex items-center justify-center">
          <div class="max-w-4xl mx-auto px-6 py-16 w-full">
            <header class="text-center mb-12">
              <h1 class="text-4xl font-bold mb-2 font-bebas">お問い合わせ</h1>
              <p class="text-muted-foreground">お気軽にご連絡ください。</p>
            </header>

            <div class="flex flex-wrap justify-center gap-2">
              {
                contacts.map((item) => {
                  const Icon = item.icon;

                  return (
                    <a
                      href={item.href}
                      target="_blank"
                      class="contact-pill"
                    >
                      <Icon class="w-4 h-4 flex-shrink-0" />
                      {item.label}
                    </a>
                  );
                })
              }
            </div>
          </div>
        </div>
      </TooltipProvider>
    </SidebarLayout>
  </body>
</html>

<style>
  .contact-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: oklch(0.97 0 0);
    background-color: oklch(0.141 0.005 285.823);
    font-size: 1rem;
    padding: 0.5rem 1.5rem;
    border-radius: 9999px;
    text-decoration: none;
    white-space: nowrap;
  }

  .contact-pill:hover {
    background-color: oklch(0.2 0.005 285.823);
  }
</style>
