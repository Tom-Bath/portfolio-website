---
import "../styles/global.css";

import { Mail, Linkedin, Github, ArrowUpRight } from "lucide-react";

const contacts = [
  {
    icon: Mail,
    label: "Email",
    value: "tom.bath.connect@gmail.com",
    href: "mailto:tom.bath.connect@gmail.com",
  },
  {
    icon: Linkedin,
    label: "LinkedIn",
    value: "linkedin.com/in/tom-bath",
    href: "https://linkedin.com/in/tom-bath",
  },
  {
    icon: Github,
    label: "GitHub",
    value: "github.com/Tom-Bath",
    href: "https://github.com/Tom-Bath",
  },
];
---

<main class="max-w-2xl mx-auto px-6 py-16">
  <!-- Header -->
  <header class="text-center mb-12">
    <h1 class="text-4xl font-bold mb-2">Contact</h1>
    <p class="text-muted-foreground">Feel free to reach out.</p>
  </header>

  <!-- Contact List -->
  <div class="space-y-6">
    {
      contacts.map((item) => {
        const Icon = item.icon;

        return (
          <a href={item.href} target="_blank" class="block">
            <div class="flex items-center gap-4 px-6 py-4 border border-border rounded-lg hover:bg-muted/40 transition-colors">
              <Icon class="w-5 h-5 text-muted-foreground flex-shrink-0" />
              <span class="font-semibold">{item.label}</span>
              <span class="ml-auto">
                <ArrowUpRight class="w-5 h-5 text-muted-foreground flex-shrink-0" />
              </span>
            </div>
          </a>
        );
      })
    }
  </div>
</main>
