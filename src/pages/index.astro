---
import "../styles/global.css";

import processviewsmall from "../content/case-studies/processviewsmall.svg";
import virtualscene from "../content/case-studies/virtualscene.png";

import {
  Card,
  CardTitle,
  CardHeader,
  CardDescription,
  CardContent,
} from "@/components/ui/card";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tom Bath - UX Portfolio</title>
  </head>
  <body class="bg-background text-foreground">
    <a
      href={`${import.meta.env.BASE_URL}/ja/`}
      class="fixed top-4 right-4 z-50 px-3 py-1.5 text-sm font-medium border border-border rounded-md bg-background hover:bg-muted/40 transition-colors"
    >
      日本語
    </a>
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <!-- Hero / intro -->
      <section class="mb-8 text-center">
        <h1 class="text-8xl font-bold mb-4 font-bebas">Tom Bath</h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          UX engineer exploring interaction design, spatial computing, and
          complex systems.
        </p>
      </section>

      <!-- Case studies -->
      <section class="grid gap-8 grid-cols-1 md:grid-cols-3">
        <!-- Kaizen Layout App -->
        <a
          href={`${import.meta.env.BASE_URL}/warehouse-flow`}
          class="no-underline block transform transition-transform duration-300 md:hover:scale-105"
        >
          <Card class="hover:shadow-lg">
            <img
              class="h-72 w-full object-cover"
              src={processviewsmall.src}
              alt="Kaizen Layout App"
            />
            <CardHeader>
              <CardTitle>Kaizen Layout App</CardTitle>
              <CardDescription>
                Concept product inspired by industrial layout tools.
              </CardDescription>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-muted-foreground">
                Wireframes, concept sketches, and interaction flows for a
                canvas-based layout application.
              </p>
            </CardContent>
          </Card>
        </a>

        <!-- XR Navigation -->
        <a
          href={`${import.meta.env.BASE_URL}/xr-navigation`}
          class="no-underline block transform transition-transform duration-300 md:hover:scale-105"
        >
          <Card class="hover:shadow-lg">
            <img
              class="h-72 w-full object-cover"
              src={virtualscene.src}
              alt="XR Navigation"
            />
            <CardHeader>
              <CardTitle>XR Navigation</CardTitle>
              <CardDescription>
                Spatial navigation UX built during my work at ABC123.
              </CardDescription>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-muted-foreground">
                Designing spatial navigation patterns for augmented reality
                environments.
              </p>
            </CardContent>
          </Card>
        </a>
      </section>
    </main>
  </body>
</html>
