---
import "../styles/global.css";

import {
  Card,
  CardTitle,
  CardHeader,
  CardDescription,
  CardContent,
} from "@/components/ui/card";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tom Bath - UX Portfolio</title>
  </head>
  <body class="bg-background text-foreground">
    <a
      href={`${import.meta.env.BASE_URL}/ja/`}
      class="fixed top-4 right-4 z-50 px-3 py-1.5 text-sm font-medium border border-border rounded-md bg-background hover:bg-muted/40 transition-colors"
    >
      日本語
    </a>
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <!-- Hero / intro -->
      <section class="mb-8 text-center">
        <h1 class="text-8xl font-bold mb-4 font-bebas">Tom Bath</h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          UX engineer exploring interaction design, spatial computing, and complex systems.
        </p>
      </section>

      <!-- Case studies -->
      <section class="grid gap-8 grid-cols-1 md:grid-cols-3">
        <!-- Kaizen Layout App -->
        <a
          href={`${import.meta.env.BASE_URL}/warehouse-flow`}
          class="no-underline block transform transition-transform duration-300 md:hover:scale-105"
        >
          <Card class="hover:shadow-lg">
            <img
              class="h-72 w-full object-cover"
              src="portfolio-website/case-studies/processviewsmall.svg"
              alt="Placeholder image"
            />
            <CardHeader>
              <CardTitle>Kaizen Layout App</CardTitle>
              <CardDescription>
                Concept product inspired by industrial layout tools.
              </CardDescription>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-muted-foreground">
                Wireframes, concept sketches, and interaction flows for a canvas-based layout application.
              </p>
            </CardContent>
          </Card>
        </a>

        <!-- XR Navigation -->
        <a
          href={`${import.meta.env.BASE_URL}/xr-navigation`}
          class="no-underline block transform transition-transform duration-300 md:hover:scale-105"
        >
          <Card class="hover:shadow-lg">
            <img
              class="h-72 w-full object-cover"
              src="portfolio-website/case-studies/virtualscene.png"
              alt="XR Navigation"
            />
            <CardHeader>
              <CardTitle>XR Navigation</CardTitle>
              <CardDescription>
                Spatial navigation UX built during my work at ABC123.
              </CardDescription>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-muted-foreground">
                Designing spatial navigation patterns for augmented reality environments.
              </p>
            </CardContent>
          </Card>
        </a>

        <!-- Google Maps Route Planner -->
        <a
          href={`${import.meta.env.BASE_URL}/maps-route-planner`}
          class="no-underline block transform transition-transform duration-300 md:hover:scale-105"
        >
          <Card class="hover:shadow-lg">
            <img
              class="h-72 w-full object-cover"
              src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 240'%3E%3Crect width='400' height='240' fill='%23e2e8f0'/%3E%3Ctext x='50%25' y='50%25' dominant-baseline='middle' text-anchor='middle' fill='%239ca3af' font-family='system-ui' font-size='24'%3EImage%3C/text%3E%3C/svg%3E"
              alt="Placeholder image"
            />
            <CardHeader>
              <CardTitle>Google Maps Route Planner</CardTitle>
              <CardDescription>
                Improving multi-destination planning workflows.
              </CardDescription>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-muted-foreground">
                Improving multi-stop route planning and interaction patterns for travellers.
              </p>
            </CardContent>
          </Card>
        </a>
      </section>
    </main>
  </body>
</html>
