---
import { TooltipProvider } from "@/components/ui/tooltip";
import { SidebarLayout } from "@/components/sidebar-layout";

import "../styles/global.css";

const { title, subtitle, heroImage, locale = "en" } = Astro.props;
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preload" as="font" type="font/woff2" href="/portfolio-website/fonts/dm-sans-latin-regular.woff2" crossorigin />
    <link rel="preload" as="font" type="font/ttf" href="/portfolio-website/fonts/BebasNeue-Regular.ttf" crossorigin fetchpriority="high" />

    <title>{title}</title>
  </head>
  <body class="bg-background text-foreground">
    <SidebarLayout client:load title={title} baseUrl={import.meta.env.BASE_URL} locale={locale} invertHeader={true}>
      <TooltipProvider client:load>
        <div class="flex-1">
          <section id="case-hero" class="bg-foreground text-background">
            <div class="max-w-4xl mx-auto px-4 pt-12 md:px-6 text-center">
              <h1 class="text-6xl font-bold mb-2 font-bebas">{title}</h1>
              {subtitle && <p class="text-lg opacity-70">{subtitle}</p>}
            </div>
          </section>

          {heroImage && (
            <div id="case-hero-img-wrap" class="relative z-10 max-w-4xl mx-auto px-4 md:px-6">
              <img
                id="case-hero-img"
                src={heroImage}
                alt={title}
                class="rounded-lg shadow-lg w-full block"
              />
            </div>
          )}

          <div class="max-w-4xl mx-auto px-4 pt-6 pb-8 md:px-6 md:pb-16 w-full">
            <article class="mx-auto space-y-12 prose prose-neutral dark:prose-invert">
              <slot />
            </article>
          </div>
        </div>
      </TooltipProvider>
    </SidebarLayout>
    {heroImage && (
      <script>
        function adjustHeroLayout() {
          const img = document.getElementById("case-hero-img") as HTMLImageElement | null;
          const hero = document.getElementById("case-hero") as HTMLElement | null;
          const wrap = document.getElementById("case-hero-img-wrap") as HTMLElement | null;
          if (!img || !hero || !wrap) return;

          const halfH = img.offsetHeight / 2;
          const gap = 24; // px gap between subtitle and image top
          hero.style.paddingBottom = (halfH + gap) + "px";
          wrap.style.marginTop = "-" + halfH + "px";
        }

        const img = document.getElementById("case-hero-img") as HTMLImageElement | null;
        if (img) {
          if (img.complete && img.naturalHeight > 0) {
            adjustHeroLayout();
          } else {
            img.addEventListener("load", adjustHeroLayout);
          }
          window.addEventListener("resize", adjustHeroLayout);
        }
      </script>
    )}

    <script type="module" is:inline>
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";

      document.querySelectorAll("pre > code.language-mermaid").forEach((el) => {
        const div = document.createElement("div");
        div.className = "mermaid";
        div.textContent = el.textContent ?? "";
        el.parentElement.replaceWith(div);
      });

      const isDark = document.documentElement.classList.contains("dark");
      mermaid.initialize({ startOnLoad: true, theme: isDark ? "dark" : "neutral" });
    </script>
  </body>
</html>
