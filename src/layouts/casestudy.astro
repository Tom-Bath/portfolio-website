---
import { TooltipProvider } from "@/components/ui/tooltip";
import { SidebarLayout } from "@/components/sidebar-layout";

import "../styles/global.css";

const { title, subtitle, heroImage, locale = "en" } = Astro.props;
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preload" as="font" type="font/woff2" href="/portfolio-website/fonts/dm-sans-latin-regular.woff2" crossorigin />
    <link rel="preload" as="font" type="font/ttf" href="/portfolio-website/fonts/BebasNeue-Regular.ttf" crossorigin fetchpriority="high" />

    <title>{title}</title>
  </head>
  <body class="bg-background text-foreground">
    <SidebarLayout client:load title={title} baseUrl={import.meta.env.BASE_URL} locale={locale}>
      <TooltipProvider client:load>
        <div class="flex-1 flex items-center justify-center">
          <div class="max-w-4xl mx-auto px-4 py-8 md:px-6 md:py-16 w-full">
            <header class="mb-12 text-center">
              <h1 class="text-6xl font-bold mb-2 font-bebas">{title}</h1>

              {subtitle && <p class="text-lg text-muted-foreground">{subtitle}</p>}

              {
                heroImage && (
                  <img
                    src={heroImage}
                    alt={title}
                    class="mt-6 rounded-lg shadow-lg"
                  />
                )
              }
            </header>

            <article
              class="mx-auto space-y-12 prose prose-neutral dark:prose-invert"
            >
              <slot />
            </article>
          </div>
        </div>
      </TooltipProvider>
    </SidebarLayout>
    <script type="module" is:inline>
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";

      document.querySelectorAll("pre > code.language-mermaid").forEach((el) => {
        const div = document.createElement("div");
        div.className = "mermaid";
        div.textContent = el.textContent ?? "";
        el.parentElement.replaceWith(div);
      });

      const isDark = document.documentElement.classList.contains("dark");
      mermaid.initialize({ startOnLoad: true, theme: isDark ? "dark" : "neutral" });
    </script>
  </body>
</html>
